# Backend environment configuration — DO NOT COMMIT THIS FILE
# Copy this file to .env and fill in your values

# ── Email Sending (Gmail) ──────────────────────────────────
# 1. Enable 2-Factor Authentication on your Gmail account.
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Create a new App Password and paste it below.
# Leave blank to print OTPs to the terminal (dev mode).
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ── Security ───────────────────────────────────────────────
# Replace with any long random string (min 32 chars)
JWT_SECRET=aurascore-super-secret-change-me-in-production
